# ─── Django Core ─────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Supabase / PostgreSQL Database ──────────────────────────
# Get these from: Supabase Dashboard → Project Settings → Database
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-supabase-db-password
DB_HOST=db.xxxxxxxxxxxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_SSLMODE=require

# ─── Email ────────────────────────────────────────────────────
# For development, use console backend (prints to terminal)
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# For production, use SMTP:
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@swiftpos.com

# ─── Manager Contact ─────────────────────────────────────────
MANAGER_EMAIL=manager@swiftpos.com
MANAGER_PHONE=+233000000000

# ─── Mobile Money ────────────────────────────────────────────
MOMO_MERCHANT_ID=SWIFTPOS-MERCHANT-001
